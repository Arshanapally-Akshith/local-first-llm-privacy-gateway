# .env.example — documents every configuration variable this gateway reads.
# Copy to `.env` and fill in real values. Never commit `.env` itself.

# Which upstream the proxy forwards to: "mock" (default — no key, no
# network, no cost) or "live" (a real OpenAI-compatible provider).
UPSTREAM_MODE=mock

# Upstream endpoint. Required in BOTH modes — no code-level default,
# so this must always be set explicitly, never silently inherited. For
# mock mode, point this at the mock upstream (see `tasks.ps1 mock`,
# which serves it on this port); for live mode, use the provider's real
# API base URL instead.
UPSTREAM_BASE_URL=http://127.0.0.1:8081

# Upstream request timeout, in seconds. Defaults to 30 — a guess, not a
# measurement (see docs/PHASE_1_SUMMARY.md / src/core/config.py).
UPSTREAM_TIMEOUT=30

# FF1 key used to derive format-preserving surrogates (used starting
# Phase 2). Required, no default — startup fails without it. Treat as a
# secret: generate a strong random value, never reuse across environments,
# never commit a real one.
FPE_KEY=

# Session map TTL, in seconds. Required, no default: this is a security
# control bounding how long PII sits in process memory, so its value must
# be a conscious choice, not an inherited one.
SESSION_TTL=

# Detector-failure behaviour: "open" (forward unsanitised on failure) or
# "closed" (503 on failure). No safe default exists — see ARCHITECTURE.md,
# Error Handling. You must choose one explicitly.
FAIL_MODE=

# Logging verbosity: DEBUG | INFO | WARNING | ERROR | CRITICAL.
# No level, including DEBUG, ever permits plaintext PII in logs.
LOG_LEVEL=INFO

# Tier-2 (PERSON/ORG/ADDRESS) model identifier, Phase 4. Defaults to
# the model chosen after a measured evaluation against gliner_small-v2.1
# and other GLiNER-class checkpoints (see docs/DECISIONS.md, Phase 4
# Task 2) - override only if you have a specific reason to.
NER_MODEL=urchade/gliner_multi_pii-v1

# Whether to load and run one warm-up inference through the Tier-2
# model at startup, before the server binds. Leave true unless you have
# a specific reason to skip it - disabling this lets cold-start cost
# hide inside the first real request's latency instead of being paid,
# measured, and reported once at boot (BUILD.md, Phase 4).
NER_WARMUP=true
